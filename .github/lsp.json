{
  "lspServers": {
    "csharp": {
      "command": "dnx",
      "args": [
        "--yes",
        "--prerelease",
        "roslyn-language-server",
        "--",
        "--stdio",
        "--autoLoadProjects"
      ],
      "fileExtensions": {
        ".cs": "csharp",
        ".cshtml": "csharp"
      }
    }
  }
}
